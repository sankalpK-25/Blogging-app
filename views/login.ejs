<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include("./partials/head") %>
    <title>Log in Page</title>
</head>
<body>
    <%- include("./partials/nav") %>
    
    <div class="container mt-4" style="max-width: 720px;">
    <div class="card p-3" style="border: 1px solid #d8e1ea; border-radius: 12px;">
    <form method="post" action="/user/login">
       <div class="mb-3 ">
        <label for="email" class="form-label">Email address:</label>
        <input type="email" class="form-control" name="email" style="border: 2px solid grey; border-radius: 5px;" id="email" aria-describedby="emailHelp">
      </div>
      <div class="mb-3">
        <label for="password" class="form-label">Password:</label>
        <input type="password" class="form-control" name="password" style="border: 2px solid grey; border-radius: 5px;" id="password">
      </div>
      <button type="submit" class="btn btn-primary">Login</button>

     <% if (locals.error) { %>
      <div class="alert alert-danger mt-10" role="alert" style="margin-top: 10px;">
        <%= error %>
      </div>
     <% } %>

    </form>
    </div>
    </div>


</body>
<%- include("./partials/script") %>
</html>
