<!-- Bootstrap default (light) -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
<style>
    body{
        background: #2b2b2f;
    }
    /* Make all div backgrounds match site background and use white text */
    div {
        background: #2b2b2f !important;
        color: #ffffff !important;
    }
    /* Light grey box shadow for cards to improve separation on dark background */
    .card {
        box-shadow: 0 6px 18px rgba(200,200,200,0.12) !important;
        background-clip: padding-box;
        color: #ffffff;
    }
    /* Ensure common text elements remain readable inside inputs and buttons */
    input, textarea, select, .btn {
        color: #ffffff !important;
    }
</style>